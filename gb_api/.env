# This is .env template, replace the variable with your own secret key used by JWT signiture.
# DO NOT share your .env anyone.

# --- Gb-api ---
# JWT keys should be hex string, 64 chars, converted into 32 bytes
JWT_KEY=123abc...
JWT_REFRESH_KEY=123abc...

# Uploaded media path in the container
UPLOAD_DIR=/srv/uploads

# Per-category upload caps (MiB). If you raise MAX_AUDIO_MB, also bump
# client_max_body_size in nginx/conf.d/default.conf to match.
MAX_IMAGE_MB=10
MAX_AUDIO_MB=25

# --- Postgres ---
# Credentials for the postgres container (consumed by the official image).
POSTGRES_USER=gb
POSTGRES_PASSWORD=gb
POSTGRES_DB=gb

# Connection string used by the API. Host "postgres" is the compose service name.
DATABASE_URL=postgres://gb:gb@postgres:5432/gb?sslmode=disable

# --- Seed admin account ---
# The database is seeded with this admin user on startup so you can log in.
# Change these before deploying.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
